generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "sqlite"
}

model User {
  id           String   @id @default(cuid())
  email        String   @unique
  passwordHash String
  username     String   @unique
  displayName  String
  role         String   @default("researcher") // "researcher" | "company" | "admin"
  avatar       String?
  bio          String?
  reputation   Int      @default(0)
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  company      Company?
  reports      Report[]   @relation("ReporterReports")
  triageReports Report[]  @relation("TriagerReports")
  comments     Comment[]
  payments     Payment[]

  @@map("users")
}

model Company {
  id          String   @id @default(cuid())
  userId      String   @unique
  name        String
  website     String?
  description String?
  logoUrl     String?
  verified    Boolean  @default(false)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  user     User      @relation(fields: [userId], references: [id])
  programs Program[]

  @@map("companies")
}

model Program {
  id           String   @id @default(cuid())
  companyId    String
  name         String
  slug         String   @unique
  description  String
  scope        String
  outOfScope   String
  status       String   @default("active")
  minBounty    Float    @default(0)
  maxBounty    Float    @default(0)
  totalPaid    Float    @default(0)
  responseTime Int      @default(7)
  logoUrl      String?
  coverUrl     String?
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  company Company  @relation(fields: [companyId], references: [id])
  reports Report[]

  @@map("programs")
}

model Report {
  id               String   @id @default(cuid())
  programId        String
  reporterId       String
  triagerId        String?
  title            String
  description      String
  impact           String
  stepsToReproduce String
  severity         String   @default("medium")
  status           String   @default("new")
  cvssScore        Float?
  cveId            String?
  bountyAmount     Float?
  attachments      String   @default("[]")
  // TLSNotary proof fields
  tlsProof         String?  // Proof payload: legacy JSON or base64-encoded .presentation.tlsn
  tlsProofFormat   String?  // "legacy_json" | "presentation_tlsn"
  tlsProofFileName String?  // Original uploaded proof filename
  tlsProofStatus   String?  // "pending" | "verified" | "invalid"
  tlsProofServerName String? // Verified server hostname from proof
  tlsProofTime     DateTime? // Time of the verified TLS session
  tlsProofSentData String?  // Redacted HTTP request from proof
  tlsProofRecvData String?  // Redacted HTTP response from proof
  createdAt        DateTime @default(now())
  updatedAt        DateTime @updatedAt

  program  Program   @relation(fields: [programId], references: [id])
  reporter User      @relation("ReporterReports", fields: [reporterId], references: [id])
  triager  User?     @relation("TriagerReports", fields: [triagerId], references: [id])
  comments Comment[]
  payment  Payment?

  @@map("reports")
}

model Comment {
  id         String   @id @default(cuid())
  reportId   String
  userId     String
  content    String
  isInternal Boolean  @default(false)
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt

  report Report @relation(fields: [reportId], references: [id])
  user   User   @relation(fields: [userId], references: [id])

  @@map("comments")
}

model Payment {
  id        String    @id @default(cuid())
  reportId  String    @unique
  userId    String
  amount    Float
  currency  String    @default("USD")
  status    String    @default("pending")
  paidAt    DateTime?
  createdAt DateTime  @default(now())

  report Report @relation(fields: [reportId], references: [id])
  user   User   @relation(fields: [userId], references: [id])

  @@map("payments")
}
